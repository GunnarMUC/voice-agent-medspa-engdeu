# Voice Agent MedSpa – Beispiel-Konfiguration
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an.

# === Ollama (LLM & Embeddings) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# === Speech-to-Text (faster-whisper) ===
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# === Text-to-Speech (Piper) ===
TTS_DE_MODEL_PATH=tts-models/de_DE-thorsten-high.onnx
TTS_EN_MODEL_PATH=tts-models/en_US-amy-medium.onnx

# === RAG (ChromaDB) ===
CHROMA_DB_PATH=./chroma_db
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=3

# === Booking API ===
BOOKING_API_HOST=0.0.0.0
BOOKING_API_PORT=8080
BOOKING_DB_PATH=./booking.db

# === LiveKit (optional, für Cloud-Voice) ===
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# === Agent ===
AGENT_DEFAULT_LANGUAGE=de

# === Logging ===
LOG_LEVEL=INFO
